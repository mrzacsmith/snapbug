#!/bin/sh
# Auto-bump patch version in extension/manifest.json when extension files change

MANIFEST="extension/manifest.json"

# Only bump if extension files are staged
if ! git diff --cached --name-only | grep -q "^extension/"; then
  exit 0
fi

# Don't bump if manifest.json is the only extension file staged (avoid loop)
STAGED_EXT_FILES=$(git diff --cached --name-only | grep "^extension/" | grep -v "^extension/manifest.json$" | wc -l | tr -d ' ')
if [ "$STAGED_EXT_FILES" = "0" ]; then
  exit 0
fi

# Read current version
CURRENT=$(node -e "console.log(require('./$MANIFEST').version)")
if [ -z "$CURRENT" ]; then
  exit 0
fi

# Increment patch
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

# Update manifest
node -e "
const fs = require('fs');
const m = JSON.parse(fs.readFileSync('$MANIFEST', 'utf8'));
m.version = '$NEW_VERSION';
fs.writeFileSync('$MANIFEST', JSON.stringify(m, null, 2) + '\n');
"

git add "$MANIFEST"
echo "Version bumped: $CURRENT → $NEW_VERSION"
