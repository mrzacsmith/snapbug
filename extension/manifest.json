{
  "manifest_version": 3,
  "name": "SnapBug",
  "version": "1.0.14",
  "description": "Capture, annotate, and upload screenshots for bug reports",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons-dev/icon16.png",
      "48": "icons-dev/icon48.png",
      "128": "icons-dev/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons-dev/icon16.png",
    "48": "icons-dev/icon48.png",
    "128": "icons-dev/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "capture-screenshot": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Capture visible tab and open annotation editor"
    }
  }
}
